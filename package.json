{
  "name": "devoteam-world-cup-2026",
  "version": "1.0.0",
  "private": true,
  "description": "Devoteam World Cup Sales Challenge 2026 — leaderboard platform (static HTML) + Playwright E2E tests.",
  "scripts": {
    "serve": "node tests/server.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:mobile": "playwright test --project=\"Mobile Safari\" --project=\"Mobile Chrome\"",
    "report": "playwright show-report",
    "codegen": "playwright codegen http://localhost:4173",
    "trace": "playwright show-trace",
    "pw:install": "playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0"
  }
}
